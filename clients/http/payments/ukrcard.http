### UKRCARD payment
@ukrCardAccount = 1234567890123456

< {% import { signCapitalistRequest } from "../sign-capitalist.js"; signCapitalistRequest(request, crypto); %}
POST {{baseUrl}}/v1/payment
API-Key: {{apiKey}}
X-Request-Timestamp: {{timestamp}}
Signature: {{signature}}
Content-Type: application/json

{
  "userRequestId": "ukrcard-{{$timestamp}}",
  "accountFrom": "{{fromAccount}}",
  "amount": 100,
  "currency": "{{currency}}",
  "comment": "UKRCARD payout example",
  "payload": {
    "type": "UKRCARD",
    "account": "{{ukrCardAccount}}",
    "autosplit": false
  }
}
