### BRBANK payment
< {% import { signCapitalistRequest } from "../sign-capitalist.js"; signCapitalistRequest(request, crypto); %}
POST {{baseUrl}}/v1/payment
API-Key: {{apiKey}}
X-Request-Timestamp: {{timestamp}}
Signature: {{signature}}
Content-Type: application/json

{
  "userRequestId": "brbank-{{$timestamp}}",
  "accountFrom": "{{fromAccount}}",
  "amount": 100,
  "currency": "{{currency}}",
  "comment": "BRBANK payout example",
  "payload": {
    "type": "BRBANK",
    "taxId": "12345678901",
    "name": "Joao Silva",
    "email": "beneficiary@example.com",
    "additionalRemark": "Own funds"
  }
}
